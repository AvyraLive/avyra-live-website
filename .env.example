# Copier ce fichier en .env et personnaliser les valeurs
SECRET_KEY=votre-cle-secrete-aleatoire-ici
ADMIN_USERNAME=admin
ADMIN_PASSWORD=votre-mot-de-passe-fort

# --- Formulaire de contact : envoi SMTP (Gmail) ---
# SMTP_USER = compte Gmail expediteur (ex: contact@avyra-live.fr)
# SMTP_PASSWORD = mot de passe d'application Gmail dedie au site (16 car.)
# CONTACT_RECIPIENT = adresse qui recoit les messages
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@avyra-live.fr
SMTP_PASSWORD=
CONTACT_RECIPIENT=contact@avyra-live.fr
