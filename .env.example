# Copier ce fichier en .env et personnaliser les valeurs
SECRET_KEY=votre-cle-secrete-aleatoire-ici
ADMIN_USERNAME=admin
ADMIN_PASSWORD=votre-mot-de-passe-fort

# --- Formulaire de contact : envoi via API Gmail (HTTPS, compatible Render) ---
# Render bloque le SMTP → on passe par l'API Gmail + compte de service + delegation.
# Sur Render : deposer la cle JSON en "Secret File" -> /etc/secrets/google-service-account.json
GOOGLE_SERVICE_ACCOUNT_FILE=/etc/secrets/google-service-account.json
GOOGLE_DELEGATED_USER=fabrice@avyra-live.fr
CONTACT_RECIPIENT=contact@avyra-live.fr
